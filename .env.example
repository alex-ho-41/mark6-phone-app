# Vercel API base URL (without trailing slash)
EXPO_PUBLIC_API_URL=https://your-vercel-app.vercel.app/api

# API Key (must match backend API_KEY)
EXPO_PUBLIC_API_KEY=your-secret-api-key-here

# AdMob App IDs (required for react-native-google-mobile-ads plugin)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXX~XXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXX~XXXXXXXX

# AdMob Ad Unit IDs
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=ca-app-pub-XXXXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=ca-app-pub-XXXXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_BANNER=ca-app-pub-XXXXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=ca-app-pub-XXXXXXXX/XXXXXXXX

# Force test ads (set to 'true' for dev/preview builds)
EXPO_PUBLIC_FORCE_TEST_ADS=true
